  pointer-events:none;z-index:1;opacity:0.35;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:18px 40px;
  background:linear-gradient(to bottom,rgba(8,8,8,0.97) 0%,transparent 100%);
  backdrop-filter:blur(10px);}
.nav-logo{display:flex;align-items:center;gap:12px;text-decoration:none;}
.nav-logo img{width:44px;height:44px;object-fit:contain;filter:invert(1);}
.nav-logo-text{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:0.2em;color:var(--white);}
.nav-links{display:flex;gap:28px;list-style:none;}
.nav-links a{font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color 0.2s;}
.nav-links a:hover{color:var(--gold);}
.nav-cta{display:flex;align-items:center;gap:8px;font-size:0.68rem;letter-spacing:0.15em;text-transform:uppercase;
  color:var(--black);background:var(--gold);padding:9px 20px;text-decoration:none;transition:all 0.2s;}
.nav-cta:hover{background:var(--gold2);}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;
  position:relative;padding:120px 40px 80px;text-align:center;overflow:hidden;}
.hero-bg{position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 50% at 50% 60%,rgba(201,168,76,0.07) 0%,transparent 70%),
             radial-gradient(ellipse 40% 30% at 20% 80%,rgba(201,168,76,0.04) 0%,transparent 60%);}
.hero-ring{position:absolute;border-radius:50%;border:1px solid rgba(201,168,76,0.07);
  top:50%;left:50%;transform:translate(-50%,-50%);animation:pulse 8s ease-in-out infinite;}
.hero-ring:nth-child(2){width:500px;height:500px;animation-delay:0s;}
.hero-ring:nth-child(3){width:750px;height:750px;animation-delay:2.5s;}
.hero-ring:nth-child(4){width:1000px;height:1000px;animation-delay:5s;}
@keyframes pulse{0%,100%{opacity:0.4}50%{opacity:0.1}}
.hero-eyebrow{font-size:0.62rem;letter-spacing:0.35em;text-transform:uppercase;color:var(--gold);
  margin-bottom:20px;position:relative;z-index:2;display:flex;align-items:center;gap:12px;}
.hero-eyebrow::before,.hero-eyebrow::after{content:'';width:36px;height:1px;background:var(--gold);opacity:0.4;}
.hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(3.5rem,9vw,7.5rem);
  font-weight:300;letter-spacing:0.06em;line-height:0.92;color:var(--white);position:relative;z-index:2;margin-bottom:6px;}
.hero-title em{font-style:italic;color:var(--gold);}
.hero-subtitle{font-family:'Cormorant Garamond',serif;font-size:clamp(0.95rem,2vw,1.3rem);
  font-weight:300;letter-spacing:0.1em;color:var(--off);margin-top:18px;position:relative;z-index:2;}
.hero-divider{width:1px;height:56px;background:linear-gradient(to bottom,var(--gold),transparent);margin:36px auto 0;position:relative;z-index:2;}

/* INFO STRIP */
.info-strip{display:flex;justify-content:center;gap:0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);
  background:var(--dark);flex-wrap:wrap;}
.info-item{padding:16px 28px;border-right:1px solid var(--border);display:flex;align-items:center;gap:10px;flex:1;min-width:160px;}
.info-item:last-child{border-right:none;}
.info-icon{font-size:1rem;}
.info-text{font-size:0.68rem;color:var(--off);letter-spacing:0.05em;line-height:1.4;}
.info-text strong{display:block;color:var(--white);font-size:0.72rem;}

/* FILTERS */
.filter-section{padding:48px 40px 28px;position:relative;z-index:2;}
.filter-label{font-size:0.58rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--muted);margin-bottom:14px;}
.filter-bar{display:flex;gap:8px;flex-wrap:wrap;}
.filter-btn{font-size:0.67rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--off);
  background:transparent;border:1px solid var(--border2);padding:8px 18px;cursor:pointer;
  transition:all 0.2s;font-family:'DM Sans',sans-serif;}
.filter-btn:hover{border-color:var(--gold);color:var(--gold);}
.filter-btn.active{background:var(--gold-dim);border-color:var(--gold);color:var(--gold);}

/* CATALOG GRID */
.catalog-section{padding:0 40px 80px;position:relative;z-index:2;}
.catalog-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(310px,1fr));gap:2px;}

/* PRODUCT CARD */
.product-card{background:var(--card);position:relative;overflow:hidden;cursor:pointer;
  animation:cardIn 0.5s ease both;transition:transform 0.2s;}
.product-card:hover{transform:translateY(-3px);}
.product-card:nth-child(2){animation-delay:.06s}
.product-card:nth-child(3){animation-delay:.12s}
.product-card:nth-child(4){animation-delay:.18s}
.product-card:nth-child(5){animation-delay:.24s}
.product-card:nth-child(6){animation-delay:.30s}
.product-card:nth-child(7){animation-delay:.36s}
.product-card:nth-child(8){animation-delay:.42s}
@keyframes cardIn{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
.product-card::after{content:'';position:absolute;inset:0;border:1px solid transparent;
  transition:border-color 0.3s;pointer-events:none;z-index:3;}
.product-card:hover::after{border-color:rgba(201,168,76,0.45);}
.product-card.featured{grid-column:span 2;}

/* CARD VISUAL */
.card-visual{position:relative;aspect-ratio:4/3;overflow:hidden;background:var(--card2);}
.product-card.featured .card-visual{aspect-ratio:16/7;}
.card-visual img{width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease;display:block;}
.product-card:hover .card-visual img{transform:scale(1.05);}
.card-visual-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,0.7) 0%,transparent 50%);z-index:1;}
.card-badge{position:absolute;top:14px;left:14px;font-size:0.58rem;letter-spacing:0.18em;
  text-transform:uppercase;padding:4px 10px;z-index:2;}
.badge-pop{background:var(--gold);color:var(--black);}
.badge-new{background:rgba(201,168,76,0.15);color:var(--gold);border:1px solid rgba(201,168,76,0.35);}
.badge-custom{background:rgba(255,255,255,0.07);color:var(--off);border:1px solid var(--border2);}

/* CARD INFO */
.card-info{padding:22px 22px 18px;border-top:1px solid var(--border);}
.card-cat{font-size:0.57rem;letter-spacing:0.24em;text-transform:uppercase;color:var(--gold);margin-bottom:7px;}
.card-name{font-family:'Cormorant Garamond',serif;font-size:1.45rem;font-weight:400;
  letter-spacing:0.02em;color:var(--white);line-height:1.1;margin-bottom:9px;}
.card-desc{font-size:0.72rem;color:var(--off);line-height:1.65;margin-bottom:14px;}
.card-specs{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:18px;}
.spec-item{display:flex;flex-direction:column;gap:2px;}
.spec-label{font-size:0.53rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);}
.spec-val{font-size:0.72rem;color:var(--off);font-weight:500;}
.card-footer{display:flex;align-items:center;justify-content:space-between;
  padding-top:14px;border-top:1px solid var(--border);}
.price-from{font-size:0.52rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);}
.price-val{font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:600;color:var(--gold);letter-spacing:0.02em;}
.card-cta{display:flex;align-items:center;gap:7px;font-size:0.6rem;letter-spacing:0.13em;
  text-transform:uppercase;color:var(--gold);padding:8px 14px;border:1px solid rgba(201,168,76,0.3);
  transition:all 0.2s;}
.card-cta:hover{background:var(--gold-dim);border-color:var(--gold);}
.card-cta svg{width:11px;height:11px;}

/* FEATURES SECTION */
.features-title{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:300;
  padding:60px 40px 32px;color:var(--white);position:relative;z-index:2;}
.features-title em{font-style:italic;color:var(--gold);}
.features-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;
  padding:0 40px 60px;position:relative;z-index:2;}
.feature-card{background:var(--card);overflow:hidden;position:relative;}
.feature-card img{width:100%;aspect-ratio:16/9;object-fit:cover;display:block;
  transition:transform 0.5s;filter:brightness(0.7);}
.feature-card:hover img{transform:scale(1.04);filter:brightness(0.85);}
.feature-overlay{position:absolute;inset:0;padding:28px;display:flex;flex-direction:column;justify-content:flex-end;
  background:linear-gradient(to top,rgba(0,0,0,0.85) 0%,transparent 55%);}
.feature-name{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:400;color:var(--white);line-height:1;}
.feature-desc{font-size:0.72rem;color:var(--off);margin-top:6px;line-height:1.55;max-width:320px;}

/* DIVIDER */
.section-divider{padding:50px 40px;display:flex;align-items:center;gap:24px;position:relative;z-index:2;}
.divider-line{flex:1;height:1px;background:var(--border);}
.divider-text{font-size:0.58rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--muted);white-space:nowrap;}

/* FEATURES STRIP */
.features-strip{display:grid;grid-template-columns:repeat(4,1fr);
  border-top:1px solid var(--border);border-bottom:1px solid var(--border);
  margin:0 40px 60px;position:relative;z-index:2;}
.feat-item{padding:28px 22px;border-right:1px solid var(--border);transition:background 0.2s;}
.feat-item:last-child{border-right:none;}
.feat-item:hover{background:rgba(201,168,76,0.03);}
.feat-icon{font-size:1.3rem;margin-bottom:10px;}
.feat-title{font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:400;color:var(--white);margin-bottom:5px;}
.feat-desc{font-size:0.68rem;color:var(--muted);line-height:1.6;}

/* CONTACT */
.contact-section{margin:0 40px 80px;padding:56px 44px;background:var(--card);
  border:1px solid var(--border);position:relative;z-index:2;overflow:hidden;
  display:flex;align-items:center;justify-content:space-between;gap:36px;flex-wrap:wrap;}
.contact-section::before{content:'';position:absolute;top:-80px;right:-80px;
  width:280px;height:280px;border-radius:50%;
  background:radial-gradient(circle,rgba(201,168,76,0.08) 0%,transparent 70%);pointer-events:none;}
.contact-text h2{font-family:'Cormorant Garamond',serif;font-size:2.4rem;font-weight:300;line-height:1.1;margin-bottom:10px;}
.contact-text h2 em{font-style:italic;color:var(--gold);}
.contact-text p{font-size:0.78rem;color:var(--off);max-width:360px;line-height:1.75;}
.contact-actions{display:flex;flex-direction:column;gap:10px;flex-shrink:0;}
.btn-wa{display:flex;align-items:center;gap:11px;padding:15px 26px;background:var(--wa);
  color:#000;text-decoration:none;font-size:0.73rem;font-weight:500;letter-spacing:0.1em;
  text-transform:uppercase;transition:all 0.2s;}
.btn-wa:hover{background:#1fb855;transform:translateY(-2px);}
.btn-wa svg{width:17px;height:17px;flex-shrink:0;}
.btn-outline{display:flex;align-items:center;justify-content:center;gap:9px;padding:13px 26px;
  border:1px solid var(--border2);color:var(--off);text-decoration:none;font-size:0.67rem;
  letter-spacing:0.13em;text-transform:uppercase;transition:all 0.2s;}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);}

/* FOOTER */
footer{padding:28px 40px;border-top:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;
  position:relative;z-index:2;}
.footer-copy{font-size:0.63rem;letter-spacing:0.1em;color:var(--muted);}
.footer-ig{display:flex;align-items:center;gap:7px;font-size:0.63rem;letter-spacing:0.1em;
  color:var(--muted);text-decoration:none;transition:color 0.2s;}
.footer-ig:hover{color:var(--gold);}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.93);z-index:200;
  display:flex;align-items:center;justify-content:center;padding:16px;
  opacity:0;pointer-events:none;transition:opacity 0.3s;backdrop-filter:blur(8px);}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--card);border:1px solid var(--border2);max-width:680px;width:100%;
  max-height:90vh;overflow-y:auto;position:relative;transform:translateY(16px);transition:transform 0.3s;}
.modal-overlay.open .modal{transform:translateY(0);}
.modal-close{position:absolute;top:14px;right:14px;background:transparent;border:1px solid var(--border2);
  color:var(--off);width:34px;height:34px;display:flex;align-items:center;justify-content:center;
  cursor:pointer;font-size:0.9rem;transition:all 0.2s;z-index:2;}
.modal-close:hover{border-color:var(--gold);color:var(--gold);}
.modal-img{width:100%;aspect-ratio:4/3;object-fit:cover;display:block;}
.modal-body{padding:28px;}
.modal-cat{font-size:0.57rem;letter-spacing:0.24em;text-transform:uppercase;color:var(--gold);margin-bottom:7px;}
.modal-name{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;margin-bottom:14px;line-height:1.1;}
.modal-desc{font-size:0.78rem;color:var(--off);line-height:1.78;margin-bottom:22px;}
.modal-specs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);
  border:1px solid var(--border);margin-bottom:26px;}
.modal-spec{background:var(--card);padding:14px;}
.modal-spec-label{font-size:0.53rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);margin-bottom:3px;}
.modal-spec-val{font-size:0.8rem;color:var(--white);font-weight:500;}
.modal-footer{display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;
  padding-top:22px;border-top:1px solid var(--border);}
.modal-price-note{font-size:0.62rem;color:var(--muted);margin-top:2px;}
.modal-price{font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:var(--gold);font-weight:600;}

/* RESPONSIVE */
@media(max-width:900px){
  nav{padding:14px 18px;}
  .nav-links{display:none;}
  .hero{padding:100px 20px 60px;}
  .filter-section,.catalog-section,.features-title,.features-grid,.features-strip,
  .contact-section,.section-divider{padding-left:18px;padding-right:18px;}
  .product-card.featured{grid-column:span 1;}
  .features-strip{grid-template-columns:repeat(2,1fr);margin:0 18px 40px;}
  .features-grid{grid-template-columns:1fr;margin:0 18px 40px;}
  .contact-section{margin:0 18px 60px;padding:36px 24px;}
  footer{padding:22px 18px;}
}
@media(max-width:480px){
  .catalog-grid{grid-template-columns:1fr;}
  .modal-specs-grid{grid-template-columns:repeat(2,1fr);}
  .features-strip{grid-template-columns:1fr;}
  .nav-cta{display:none;}
  .info-strip{flex-direction:column;}
  .info-item{border-right:none;border-bottom:1px solid var(--border);}
}
</style>
